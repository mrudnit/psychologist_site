generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BookingRequest {
  id          Int      @id @default(autoincrement())
  name        String
  age         String
  helpType    String
  format      String
  lossTiming  String
  phone       String?
  email       String?
  messengers  String   @default("[]") // JSON array stored as string
  promoCode   String?
  note        String?
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  coverUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  text      String
  createdAt DateTime @default(now())
}
